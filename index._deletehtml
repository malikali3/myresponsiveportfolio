                <circle cx="14" cy="18" r="2.2" fill="#0A0A0A"/>
                <circle cx="26" cy="18" r="2.2" fill="#0A0A0A"/>
                <path d="M17 21.5 L23 21.5 L20 26.5 Z" fill="#FFD23F"/>
                <ellipse cx="11" cy="43" rx="5" ry="2.6" fill="#FFD23F"/>
