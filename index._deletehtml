<!-- The single flying book logo lives here, as a direct child of <body> — deliberately outside
     .hero-sticky. An ancestor with position:sticky always creates its own stacking context, which
     was silently trapping the book's z-index inside the hero section and letting every later
     section paint over it. Keeping it here means its z-index actually applies against the whole page. -->
<a id="floatingBook" href="https://wa.me/923016777449" target="_blank" rel="noopener" aria-label="Book a free trial on WhatsApp">
  <svg viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg">
    <path d="M60 20 C48 10 28 8 12 12 L12 82 C28 78 48 80 60 90 Z" fill="#FF7A1A"/>
    <path class="book-page" d="M60 20 C72 10 92 8 108 12 L108 82 C92 78 72 80 60 90 Z" fill="#E5383B"/>
    <line x1="60" y1="20" x2="60" y2="90" stroke="#FFD23F" stroke-width="2"/>
  </svg>
</a>

<script>
  // ---------- loading screen: breathing logo for 5s, then fade to site ----------
  (function(){
    var loadingScreen = document.getElementById('loadingScreen');
    var LOAD_TIME = 5000;
    function hideLoader(){
      loadingScreen.classList.add('is-hidden');
      document.body.classList.remove('is-loading');
      loadingScreen.addEventListener('transitionend', function(){
        loadingScreen.remove();
      }, { once:true });
    }
    window.setTimeout(hideLoader, LOAD_TIME);
  })();

  // ---------- custom cursor ----------
  const cursor = document.getElementById('cursor');
  window.addEventListener('mousemove', e=>{
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
  });
  document.querySelectorAll('a, .card, [data-tilt], #musicToggle, .hover-text, .note-card').forEach(el=>{
    el.addEventListener('mouseenter', ()=> cursor.classList.add('hover'));
    el.addEventListener('mouseleave', ()=> cursor.classList.remove('hover'));
  });

  // ---------- hero "opening box": panels separate, headline reveals ----------
  const heroPin = document.getElementById('heroPin');
  const heroInner = document.getElementById('heroInner');
  const boxLeft = document.getElementById('boxLeft');
  const boxRight = document.getElementById('boxRight');
  const scrollCue = document.getElementById('scrollCue');
  const floatingBook = document.getElementById('floatingBook');

  function heroProgress(){
    const pinTop = heroPin.offsetTop;
    const pinHeight = heroPin.offsetHeight;
    const viewport = window.innerHeight;
    const raw = (window.scrollY - pinTop) / (pinHeight - viewport);
    return Math.min(1, Math.max(0, raw));
  }

  function updateHero(){
    const p = heroProgress();

    // the two covers slide apart like an opening box lid
    boxLeft.style.transform = `translateX(${-p*100}%)`;
    boxRight.style.transform = `translateX(${p*100}%)`;

    // headline underneath fades and rises into view as the box opens
    const reveal = Math.min(1, p*2.2);
    heroInner.style.opacity = reveal;
    heroInner.style.transform = `translateY(${(1-reveal)*16}px)`;

    if(p > 0.04){
      scrollCue.style.animation = 'none';
      scrollCue.style.opacity = 0;
    } else {
      scrollCue.style.animation = '';
      scrollCue.style.opacity = '';
    }

    // magic flake burst the moment the "door" (box lid) starts to open
    if(p > 0.02 && typeof window.spawnDoorFlakesOnce === 'function'){
      window.spawnDoorFlakesOnce();
    }
  }

  // ---------- scroll reveal ----------
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold:0.15 });
  revealEls.forEach(el=> io.observe(el));

  // ---------------------------------------------------------------------------
  // Single flying book logo — one element, three stops: hero -> circle in
  // "Meet the Teacher" -> circle in "Levels".
  //
  // Two layers:
  //  1) computeBookTarget() figures out WHERE the book should be right now,
  //     purely from scroll position — and crucially, progress is measured
  //     against the landing CIRCLE's own position, not the section's, so the
  //     book can never be reported "100% arrived" while its destination is
  //     still off-screen.
  //  2) a requestAnimationFrame loop eases the book's on-screen position
  //     toward that target every frame (not just on scroll events), which is
  //     what gives it the slow, weighty, gliding feel instead of snapping
  //     around with the scrollbar.
  // ---------------------------------------------------------------------------
  const bookCircle1 = document.getElementById('bookCircle1');
  const bookCircle2 = document.getElementById('bookCircle2');
  const BASE_BOOK_SIZE = 92; // matches #floatingBook's natural width/height in CSS
  const LAND_FILL = 0.8;     // book fills 80% of the landing anchor's size (no circle frame anymore, so it can be bigger)

  function lerp(a, b, t){ return a + (b - a) * t; }
  function smoothstep(t){ return t * t * (3 - 2 * t); } // ease-in-out, used on the raw scroll progress

  // 0 -> 1 as `el`'s own center travels from startVH of the viewport down to endVH of the viewport.
  // Wide start/end spread = more scroll distance per flight = slower, subtler motion.
  function scrollProgress(el, startVH = 1.05, endVH = 0.5){
    const rect = el.getBoundingClientRect();
    const vh = window.innerHeight;
    const centerY = rect.top + rect.height / 2;
    const start = vh * startVH, end = vh * endVH;
    const raw = (start - centerY) / (start - end);
    return smoothstep(Math.min(1, Math.max(0, raw)));
  }

  function pulseLanding(){
    floatingBook.classList.remove('just-landed');
    void floatingBook.offsetWidth; // restart the CSS animation even if triggered twice in a row
    floatingBook.classList.add('just-landed');
  }

  let landed1 = false, landed2 = false;
  const bookTarget = { x: 0, y: 0, scale: 1, rotate: 0, flying: false };

  function computeBookTarget(){
    const vw = window.innerWidth, vh = window.innerHeight;
    const isMobile = vw <= 860;
    const p = heroProgress();

    let x, y, scale, rotate = 0, flying = false;

    if(p < 1){
      // still inside the hero: the book lifts off and shrinks as the box lid opens
      x = vw / 2;
      y = vh / 2 - p * 0.46 * vh;
      scale = 1 - p * 0.55;
    } else {
      // hero finished — resting "waiting" spot, top-right corner
      const cornerSize = isMobile ? 44 : 64;
      const cornerX = isMobile ? vw - 16 - cornerSize / 2 : vw - vw * 0.05 - cornerSize / 2;
      const cornerY = isMobile ? vh - 90 - cornerSize / 2 : vh * 0.18;
      const cornerScale = cornerSize / BASE_BOOK_SIZE;

      x = cornerX; y = cornerY; scale = cornerScale;

      if(bookCircle1){
        const t1 = scrollProgress(bookCircle1);
        const r1 = bookCircle1.getBoundingClientRect();
        const c1x = r1.left + r1.width / 2, c1y = r1.top + r1.height / 2;
        const c1scale = (Math.min(r1.width, r1.height) * LAND_FILL) / BASE_BOOK_SIZE;

        x = lerp(cornerX, c1x, t1);
        y = lerp(cornerY, c1y, t1);
        scale = lerp(cornerScale, c1scale, t1);
        if(t1 > 0.002 && t1 < 0.998){
          y -= Math.sin(t1 * Math.PI) * 45;      // gentle upward arc mid-flight
          rotate = Math.sin(t1 * Math.PI * 2) * 7; // slight bank left-right, realistic 2D flutter
          flying = true;
        }

        if(t1 >= 0.998){ if(!landed1){ landed1 = true; pulseLanding(); } } else landed1 = false;

        if(bookCircle2 && t1 >= 0.998){
          const t2 = scrollProgress(bookCircle2);
          const r2 = bookCircle2.getBoundingClientRect();
          const c2x = r2.left + r2.width / 2, c2y = r2.top + r2.height / 2;
          const c2scale = (Math.min(r2.width, r2.height) * LAND_FILL) / BASE_BOOK_SIZE;

          x = lerp(c1x, c2x, t2);
          y = lerp(c1y, c2y, t2);
          scale = lerp(c1scale, c2scale, t2);
          if(t2 > 0.002 && t2 < 0.998){
            y -= Math.sin(t2 * Math.PI) * 45;
            rotate = Math.sin(t2 * Math.PI * 2) * 7;
            flying = true;
          }

          if(t2 >= 0.998){ if(!landed2){ landed2 = true; pulseLanding(); } } else landed2 = false;
        } else {
          landed2 = false;
        }
      }
    }

    bookTarget.x = x; bookTarget.y = y; bookTarget.scale = scale;
    bookTarget.rotate = rotate; bookTarget.flying = flying;
  }

  // current on-screen values, eased toward bookTarget every animation frame
  const bookCurrent = { x: 0, y: 0, scale: 1, rotate: 0, ready: false };
  const SMOOTH = 0.045; // lower = slower / more syrupy trailing motion

  function tickBook(){
    if(!bookCurrent.ready){
      // snap to the correct spot on first paint so it doesn't fly in from (0,0) on load
      bookCurrent.x = bookTarget.x; bookCurrent.y = bookTarget.y;
      bookCurrent.scale = bookTarget.scale; bookCurrent.rotate = bookTarget.rotate;
      bookCurrent.ready = true;
    } else {
      bookCurrent.x += (bookTarget.x - bookCurrent.x) * SMOOTH;
      bookCurrent.y += (bookTarget.y - bookCurrent.y) * SMOOTH;
      bookCurrent.scale += (bookTarget.scale - bookCurrent.scale) * SMOOTH;
      bookCurrent.rotate += (bookTarget.rotate - bookCurrent.rotate) * SMOOTH;
    }

    floatingBook.classList.toggle('is-flying', bookTarget.flying);
    floatingBook.style.transform =
      `translate(${bookCurrent.x}px, ${bookCurrent.y}px) translate(-50%,-50%) scale(${bookCurrent.scale}) rotate(${bookCurrent.rotate}deg)`;

    requestAnimationFrame(tickBook);
  }

  function onScrollOrResize(){
    updateHero();
    computeBookTarget();
  }
  window.addEventListener('scroll', onScrollOrResize, {passive:true});
  window.addEventListener('resize', onScrollOrResize);
  onScrollOrResize();
  requestAnimationFrame(tickBook);

  // ---------- card tilt ----------
  document.querySelectorAll('[data-tilt]').forEach(card=>{
    card.addEventListener('mousemove', e=>{
      const rect = card.getBoundingClientRect();
      const px = (e.clientX - rect.left)/rect.width - 0.5;
      const py = (e.clientY - rect.top)/rect.height - 0.5;
      card.style.transform = `perspective(700px) rotateX(${py*-8}deg) rotateY(${px*8}deg) translateY(-4px)`;
    });
    card.addEventListener('mouseleave', ()=>{
      card.style.transform = 'perspective(700px) rotateX(0) rotateY(0) translateY(0)';
    });
  });

  // ---------- magnetic button ----------
  const magBtn = document.getElementById('magBtn');
  magBtn.addEventListener('mousemove', e=>{
    const rect = magBtn.getBoundingClientRect();
    const px = (e.clientX - rect.left) - rect.width/2;
    const py = (e.clientY - rect.top) - rect.height/2;
    magBtn.style.transform = `translate(${px*0.25}px, ${py*0.5}px)`;
  });
  magBtn.addEventListener('mouseleave', ()=>{
    magBtn.style.transform = 'translate(0,0)';
  });

  // ---------- background music: plays assets/music.mp3 (drop your file in that folder) ----------
  const bgMusic = document.getElementById('bgMusic');
  const musicToggle = document.getElementById('musicToggle');
  const eqBars = musicToggle.querySelectorAll('.eq-bar');
  bgMusic.volume = 0.35;

  musicToggle.addEventListener('click', ()=>{
    if(bgMusic.paused){
      musicToggle.classList.add('is-loading');
      bgMusic.play()
        .then(()=>{
          musicToggle.classList.remove('is-loading');
          eqBars.forEach(b=> b.classList.add('playing'));
        })
        .catch(()=>{
          // most likely assets/music.mp3 hasn't been added yet
          musicToggle.classList.remove('is-loading');
          console.warn('Could not play assets/music.mp3 — make sure the file exists in your assets folder.');
        });
    } else {
      bgMusic.pause();
      eqBars.forEach(b=> b.classList.remove('playing'));
    }
  });

  // ---------- hero mini-game: tap the penguin, it races the track past each grade milestone up to A* ----------
  (function(){
    const trackPath = document.getElementById('gamePath');
    const progressPath = document.getElementById('gamePathProgress');
    const gameChar = document.getElementById('gameChar');
    const markers = document.querySelectorAll('#gameCircle .grade-marker');
    const mascot = document.getElementById('gameBookMascot');
    const sparkleHost = document.getElementById('mascotSparkles');
    const hint = document.getElementById('gameHint');
    if(!trackPath || !gameChar || !markers.length) return;

    const total = trackPath.getTotalLength();
    progressPath.style.strokeDasharray = total;
    progressPath.style.strokeDashoffset = total;

    // 6 stops along the track: E, D, C, B, A, A*
    const fractions = [0.04, 0.22, 0.40, 0.58, 0.76, 0.97];
    const points = fractions.map(f => trackPath.getPointAtLength(f * total));

    markers.forEach((m, i)=>{
      const pt = points[i];
      m.style.left = (pt.x / 300 * 100) + '%';
      m.style.top = (pt.y / 300 * 100) + '%';
    });

    function placeChar(i){
      const pt = points[i];
      gameChar.style.left = (pt.x / 300 * 100) + '%';
      gameChar.style.top = (pt.y / 300 * 100) + '%';
    }
    placeChar(0);

    let running = false, achieved = false;

    function reset(){
      markers.forEach(m => m.classList.remove('is-passed'));
      mascot.classList.remove('is-swirling');
      sparkleHost.innerHTML = '';
      progressPath.style.strokeDashoffset = total;
      placeChar(0);
      achieved = false;
      hint.classList.remove('is-hidden');
    }

    function spawnSparkles(){
      for(let i = 0; i < 16; i++){
        const s = document.createElement('span');
        s.className = 'mascot-spark';
        const angle = Math.random() * Math.PI * 2;
        const dist = 26 + Math.random() * 32;
        s.style.setProperty('--sx', Math.cos(angle) * dist + 'px');
        s.style.setProperty('--sy', Math.sin(angle) * dist + 'px');
        s.style.left = '50%'; s.style.top = '50%';
        s.style.animationDelay = (Math.random() * 0.15) + 's';
        sparkleHost.appendChild(s);
        s.addEventListener('animationend', () => s.remove());
      }
    }

    function playSequence(){
      running = true;
      hint.classList.add('is-hidden');

      fractions.forEach((f, i)=>{
        setTimeout(()=>{
          placeChar(i);
          progressPath.style.strokeDashoffset = total - (f * total);
          gameChar.classList.remove('char-hop');
          void gameChar.offsetWidth;
          gameChar.classList.add('char-hop');
          if(i > 0) markers[i].classList.add('is-passed');

          if(i === fractions.length - 1){
            running = false;
            achieved = true;
            setTimeout(()=>{
              mascot.classList.add('is-swirling');
              spawnSparkles();
            }, 220);
          }
        }, i * 650);
      });
    }

    function handleActivate(){
      if(running) return;
      if(achieved){ reset(); setTimeout(playSequence, 60); return; }
      playSequence();
    }

    // pointerdown fires the instant a finger/mouse makes contact (before the idle bob can drift
    // the target out from under a slower 'click'/'touchend' hit-test) — click/touchstart are kept
    // as redundant fallbacks for older browsers; handleActivate's `running` guard makes it safe
    // for more than one of these to fire for the same tap.
    gameChar.addEventListener('pointerdown', handleActivate);
    gameChar.addEventListener('click', handleActivate);
    gameChar.addEventListener('touchstart', handleActivate, { passive: true });
    gameChar.addEventListener('keydown', (e)=>{
      if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); handleActivate(); }
    });
  })();

  // ---------- magic flake burst when the hero "door" (box lid) opens ----------
  (function(){
    const heroStickyEl = document.getElementById('heroSticky');
    if(!heroStickyEl) return;
    const flakeHost = document.createElement('div');
    flakeHost.id = 'doorFlakes';
    flakeHost.style.cssText = 'position:absolute; inset:0; z-index:40; pointer-events:none; overflow:hidden;';
    heroStickyEl.appendChild(flakeHost);
    let fired = false;

    window.spawnDoorFlakesOnce = function(){
      if(fired) return;
      fired = true;
      for(let i = 0; i < 34; i++){
        const f = document.createElement('span');
        f.className = 'door-flake';
        const size = 4 + Math.random() * 6;
        f.style.width = size + 'px';
        f.style.height = size + 'px';
        f.style.left = (Math.random() * 100) + '%';
        f.style.top = (35 + Math.random() * 25) + '%';
        f.style.setProperty('--fx', ((Math.random() * 120) - 60) + 'px');
        f.style.animationDuration = (1.1 + Math.random() * 0.9) + 's';
        f.style.animationDelay = (Math.random() * 0.45) + 's';
        flakeHost.appendChild(f);
        f.addEventListener('animationend', () => f.remove());
      }
    };
  })();

  // ---------- liquid "sea wave" ripple: tapping/clicking any plain area of a section (i.e. not
  // text, not the book logo, not anything clickable) plays an expanding liquid ripple there.
  // Only active once the loading screen has actually opened, per request. ----------
  (function(){
    const waveLayer = document.createElement('div');
    waveLayer.id = 'waveRippleLayer';
    document.body.appendChild(waveLayer);

    // anything text-bearing, the book logo/mascot, or genuinely clickable is skipped
    const WAVE_EXCLUDE = [
      'a', 'button', 'input', 'textarea', 'select', '[role="button"]', '[tabindex]', 'svg',
      'h1', 'h2', 'h3', 'p', 'span', 'li', 'label',
      '#floatingBook', '.game-book-mascot', '.grade-marker',
      '#musicToggle', '#cursor', '.hover-text', '.card', '.note-card', '[data-tilt]'
    ].join(', ');

    function spawnRipple(x, y){
      for(let i = 0; i < 3; i++){
        const ring = document.createElement('span');
        ring.className = 'wave-ring wave-ring-' + i;
        ring.style.left = x + 'px';
        ring.style.top = y + 'px';
        ring.style.animationDelay = (i * 0.12) + 's';
        waveLayer.appendChild(ring);
        ring.addEventListener('animationend', () => ring.remove());
      }
      for(let i = 0; i < 7; i++){
        const drop = document.createElement('span');
        drop.className = 'wave-drop';
        const angle = Math.random() * Math.PI * 2;
        const dist = 20 + Math.random() * 34;
        drop.style.setProperty('--dx', Math.cos(angle) * dist + 'px');
        drop.style.setProperty('--dy', Math.sin(angle) * dist + 'px');
        drop.style.left = x + 'px';
        drop.style.top = y + 'px';
        drop.style.animationDelay = (Math.random() * 0.1) + 's';
        waveLayer.appendChild(drop);
        drop.addEventListener('animationend', () => drop.remove());
      }
    }

    document.addEventListener('pointerdown', (e)=>{
      if(document.body.classList.contains('is-loading')) return; // wait until the loading screen has opened
      if(e.target.closest(WAVE_EXCLUDE)) return;
      spawnRipple(e.clientX, e.clientY);
    });
  })();
</script>
</body>
</html>
